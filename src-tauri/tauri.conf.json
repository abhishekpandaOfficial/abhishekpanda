{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Abhishek Admin",
  "version": "0.1.0",
  "identifier": "com.abhishekpanda.admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Abhishek Admin",
        "width": 1560,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Desktop-first admin portal for the Abhishek Panda web platform.",
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
