# Core
HOST=0.0.0.0
PORT=1337
SERVER_URL=http://localhost:1337
ADMIN_PATH=/cms-admin
REST_PREFIX=/cms-api

# Security (replace before production)
APP_KEYS="replace_me_1,replace_me_2,replace_me_3,replace_me_4"
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me
ENCRYPTION_KEY=replace_me

# Rebuild hook for public site deployment (optional)
BUILD_HOOK_URL=

# Upload provider (local or aws-s3)
# Use aws-s3 for Supabase Storage S3-compatible API in production.
UPLOAD_PROVIDER=local

# S3-compatible upload settings (used when UPLOAD_PROVIDER=aws-s3)
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_FORCE_PATH_STYLE=true
# Public base URL for generated media URLs (recommended with Supabase public buckets)
UPLOAD_BASE_URL=
UPLOAD_ROOT_PATH=

# Local database (SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Production database (Supabase Postgres)
# DATABASE_CLIENT=postgres
# DATABASE_HOST=db.<project-ref>.supabase.co
# DATABASE_PORT=5432
# DATABASE_NAME=postgres
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=<supabase-db-password>
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_SCHEMA=public
