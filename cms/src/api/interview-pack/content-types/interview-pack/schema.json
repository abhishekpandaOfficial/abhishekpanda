      "target": "api::interview-category.interview-category",
      "inversedBy": "interviewPacks"
    },
    "questions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::interview-question.interview-question",
      "inversedBy": "interviewPacks"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "interviewPacks"
    }
  }
