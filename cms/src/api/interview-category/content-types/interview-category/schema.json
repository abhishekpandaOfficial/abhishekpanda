{
  "kind": "collectionType",
  "collectionName": "interview_categories",
  "info": {
    "singularName": "interview-category",
    "pluralName": "interview-categories",
    "displayName": "Interview Category"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "questions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::interview-question.interview-question",
      "mappedBy": "category"
    },
    "interviewPacks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::interview-pack.interview-pack",
      "mappedBy": "categories"
    }
  }
}
