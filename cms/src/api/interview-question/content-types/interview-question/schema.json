{
  "kind": "collectionType",
  "collectionName": "interview_questions",
  "info": {
    "singularName": "interview-question",
    "pluralName": "interview-questions",
    "displayName": "Interview Question"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "question": {
      "type": "text",
      "required": true
    },
    "answer": {
      "type": "richtext"
    },
    "difficulty": {
      "type": "enumeration",
      "enum": ["basic", "intermediate", "lead", "architect"],
      "default": "basic"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview-category.interview-category",
      "inversedBy": "questions"
    },
    "interviewPacks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::interview-pack.interview-pack",
      "mappedBy": "questions"
    }
  }
}
