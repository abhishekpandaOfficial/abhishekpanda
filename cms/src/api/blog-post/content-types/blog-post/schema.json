{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "Long-form editorial posts"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "blogPosts"
    },
    "level": {
      "type": "enumeration",
      "enum": ["basic", "intermediate", "lead", "architect"],
      "default": "basic",
      "required": true
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "contentBlocks": {
      "type": "dynamiczone",
      "components": [
        "content-blocks.rich-text",
        "content-blocks.code-block",
        "content-blocks.mermaid-diagram",
        "content-blocks.callout",
        "content-blocks.image-block",
        "content-blocks.embed",
        "content-blocks.tabs",
        "content-blocks.steps",
        "content-blocks.checklist"
      ]
    },
    "featured": {
      "type": "boolean",
      "default": false
    }
  }
}
