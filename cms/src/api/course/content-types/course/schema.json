{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "Course metadata and lesson composition"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "lessons": {
      "type": "dynamiczone",
      "components": [
        "content-blocks.rich-text",
        "content-blocks.code-block",
        "content-blocks.mermaid-diagram",
        "content-blocks.callout",
        "content-blocks.image-block",
        "content-blocks.embed",
        "content-blocks.tabs",
        "content-blocks.steps",
        "content-blocks.checklist"
      ]
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "courses"
    }
  }
}
