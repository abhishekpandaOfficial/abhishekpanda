{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/cms-admin/:path*",
      "destination": "https://abhishekpanda.onrender.com/cms-admin/:path*"
    },
    {
      "source": "/cms-api/:path*",
      "destination": "https://abhishekpanda.onrender.com/cms-api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://abhishekpanda.onrender.com/uploads/:path*"
    },
    {
      "source": "/embedded/:path*",
      "destination": "/embedded/:path*"
    },
    {
      "source": "/admin",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://abhishekpanda.onrender.com/admin/:path*"
    },
    {
      "source": "/((?!api/).*)\\.(js|mjs|css|png|jpg|jpeg|gif|svg|ico|webp|avif|map|txt|xml|webmanifest|woff|woff2|ttf|otf)$",
      "destination": "/$1.$2"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
