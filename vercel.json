{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|otf|dmg))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(manifest.webmanifest|robots.txt|rss.xml|sitemap.xml|llms.txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/cms-admin/:path*",
      "destination": "https://abhishekpanda.onrender.com/cms-admin/:path*"
    },
    {
      "source": "/cms-api/:path*",
      "destination": "https://abhishekpanda.onrender.com/cms-api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://abhishekpanda.onrender.com/uploads/:path*"
    },
    {
      "source": "/embedded/:path*",
      "destination": "/embedded/:path*"
    },
    {
      "source": "/admin",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://abhishekpanda.onrender.com/admin/:path*"
    },
    {
      "source": "/ai-closed_models_2026.html",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/open-source-models-march-2026.html",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/ai-model-comparison.html",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/).*)\\.(html|js|mjs|css|png|jpg|jpeg|gif|svg|ico|webp|avif|map|txt|xml|webmanifest|woff|woff2|ttf|otf|dmg)$",
      "destination": "/$1.$2"
    },
    {
      "source": "/((?!api/|embedded/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
